--- !u!114 &2092257983
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2092257982}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 39a74d54aaa9b20499943f11cc9d7366, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  displayName: "\u0421\u0442\u0430\u0440\u043E\u0441\u0442\u0430 \u0434\u0435\u0440\u0435\u0432\u043D\u0438"
  greetingText: "\u041F\u0443\u0442\u043D\u0438\u043A, \u0432\u043E\u043B\u043A\u043E\u0432
    \u0437\u0430 \u0441\u0435\u0432\u0435\u0440\u043D\u044B\u043C\u0438 \u0432\u043E\u0440\u043E\u0442\u0430\u043C\u0438
    \u0441\u0442\u0430\u043B\u043E \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u043C\u043D\u043E\u0433\u043E.
    \u041F\u0440\u0438\u043D\u0435\u0441\u0438 \u043C\u043D\u0435 \u043F\u044F\u0442\u044C
    \u0432\u043E\u043B\u0447\u044C\u0438\u0445 \u0445\u0432\u043E\u0441\u0442\u043E\u0432."
  activeQuestText: "\u0425\u0432\u043E\u0441\u0442 \u0432\u044B\u043F\u0430\u0434\u0430\u0435\u0442
    \u043D\u0435 \u0441 \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0432\u043E\u043B\u043A\u0430.
    \u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0439 \u043E\u0445\u043E\u0442\u0443
    \u0437\u0430 \u0441\u0435\u0432\u0435\u0440\u043D\u044B\u043C\u0438 \u0432\u043E\u0440\u043E\u0442\u0430\u043C\u0438."
  readyQuestText: "\u041F\u044F\u0442\u0438 \u0445\u0432\u043E\u0441\u0442\u043E\u0432
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E. \u0422\u0435\u043F\u0435\u0440\u044C
    \u043C\u044B \u0437\u043D\u0430\u0435\u043C, \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0432\u0435\u043B\u0438\u043A\u0430 \u0441\u0442\u0430\u044F."
  completedQuestText: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E \u0437\u0430 \u043F\u043E\u043C\u043E\u0449\u044C.
    \u0421\u0435\u0432\u0435\u0440\u043D\u0430\u044F \u0434\u043E\u0440\u043E\u0433\u0430
    \u0442\u0435\u043F\u0435\u0440\u044C \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u0435\u0435."
  questId: wolves-near-the-road
  questTitle: "\u0412\u043E\u043B\u0447\u044C\u0438 \u0442\u0440\u043E\u0444\u0435\u0438"
  questDescription: "\u0421\u0442\u0430\u044F \u0443 \u0441\u0435\u0432\u0435\u0440\u043D\u043E\u0439
    \u0434\u043E\u0440\u043E\u0433\u0438 \u0443\u0433\u0440\u043E\u0436\u0430\u0435\u0442
    \u0434\u0435\u0440\u0435\u0432\u043D\u0435. \u041F\u0440\u0438\u043D\u0435\u0441\u0438\u0442\u0435
    \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043E\u0445\u043E\u0442\u044B."
  questObjectiveText: "\u0412\u043E\u043B\u0447\u044C\u0438 \u0445\u0432\u043E\u0441\u0442\u044B"
  questTargetId: wolf_tail
  requiredObjectiveCount: 5
  rewardExperience: 80
  selectionRing: {fileID: 1220215601}
