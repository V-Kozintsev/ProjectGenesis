  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 39a74d54aaa9b20499943f11cc9d7366, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  displayName: "\u0421\u0442\u0430\u0440\u043E\u0441\u0442\u0430 \u0434\u0435\u0440\u0435\u0432\u043D\u0438"
  greetingText: "\u041F\u0443\u0442\u043D\u0438\u043A, \u0441\u0435\u0432\u0435\u0440\u043D\u0430\u044F
    \u0434\u043E\u0440\u043E\u0433\u0430 \u0441\u0442\u0430\u043B\u0430 \u043E\u043F\u0430\u0441\u043D\u043E\u0439.
    \u0412\u043E\u043B\u043A\u0438 \u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0442
    \u0432\u0441\u0451 \u0431\u043B\u0438\u0436\u0435 \u043A \u0434\u0435\u0440\u0435\u0432\u043D\u0435.
    \u0421\u043C\u043E\u0436\u0435\u0448\u044C \u043F\u043E\u043C\u043E\u0447\u044C
    \u043D\u0430\u043C?"
  activeQuestText: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E. \u041F\u043E\u043A\u0430
    \u043F\u0440\u043E\u0441\u0442\u043E \u0437\u0430\u043F\u043E\u043C\u043D\u0438
    \u043F\u043E\u0440\u0443\u0447\u0435\u043D\u0438\u0435: \u0432\u043E\u043B\u043A\u043E\u0432
    \u0438 \u0431\u043E\u0439 \u043C\u044B \u0434\u043E\u0431\u0430\u0432\u0438\u043C
    \u0432 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C \u0441\u043F\u0440\u0438\u043D\u0442\u0435."
  questId: wolves-near-the-road
  questTitle: "\u0412\u043E\u043B\u043A\u0438 \u0443 \u0434\u043E\u0440\u043E\u0433\u0438"
  questObjectiveText: "\u0411\u0443\u0434\u0443\u0449\u0430\u044F \u0446\u0435\u043B\u044C:
    \u043F\u043E\u0431\u0435\u0434\u0438\u0442\u044C 3 \u0432\u043E\u043B\u043A\u043E\u0432
    \u0443 \u0441\u0442\u0430\u0440\u043E\u0439 \u0441\u0435\u0432\u0435\u0440\u043D\u043E\u0439
    \u0434\u043E\u0440\u043E\u0433\u0438."
  selectionRing: {fileID: 1197377837}
