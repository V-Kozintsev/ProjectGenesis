  m_Script: {fileID: 11500000, guid: ad01a0dfc65327847bfc18d5be14e226, type: 3}
  m_Name: SO_Quest_WolfAlphaHunt
  m_EditorClassIdentifier: 
  questId: wolf-alpha-hunt
  displayName: "\u0412\u043E\u0436\u0430\u043A \u0441\u0442\u0430\u0438"
  description: "\u0412 \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u043E\u0439 \u043F\u043E\u043B\u044F\u043D\u0435
    \u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F \u0432\u043E\u0436\u0430\u043A
    \u0432\u043E\u043B\u043A\u043E\u0432. \u041F\u043E\u0431\u0435\u0434\u0438\u0442\u0435
    \u0435\u0433\u043E, \u0447\u0442\u043E\u0431\u044B \u043E\u0441\u043B\u0430\u0431\u0438\u0442\u044C
    \u0441\u0442\u0430\u044E \u0443 \u0441\u0435\u0432\u0435\u0440\u043D\u043E\u0439
    \u0434\u043E\u0440\u043E\u0433\u0438."
  prerequisiteQuestId: boars-near-the-road
  offerText: "\u041A\u0430\u0431\u0430\u043D\u043E\u0432 \u043E\u0442\u043E\u0433\u043D\u0430\u043B\u0438,
    \u043D\u043E \u0442\u0435\u043F\u0435\u0440\u044C \u044F\u0441\u043D\u043E, \u043F\u043E\u0447\u0435\u043C\u0443
    \u0437\u0432\u0435\u0440\u0438 \u0442\u0430\u043A \u043D\u0430\u0433\u043B\u0435\u043B\u0438.
    \u041D\u0430 \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u043E\u0439 \u043F\u043E\u043B\u044F\u043D\u0435
    \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u0432\u043E\u0436\u0430\u043A
    \u0441\u0442\u0430\u0438. \u041E\u0434\u043E\u043B\u0435\u0439 \u0435\u0433\u043E."
  activeText: "\u0412\u043E\u0436\u0430\u043A \u0432\u0441\u0451 \u0435\u0449\u0451
    \u0434\u0435\u0440\u0436\u0438\u0442 \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u0443\u044E
    \u043F\u043E\u043B\u044F\u043D\u0443. \u0421\u043B\u0435\u0434\u0438 \u0437\u0430
    \u0435\u0433\u043E \u043C\u043E\u0449\u043D\u044B\u043C \u0443\u043A\u0443\u0441\u043E\u043C
    \u0438 \u043D\u0435 \u0441\u0442\u043E\u0439 \u0440\u044F\u0434\u043E\u043C \u0432\u043E
    \u0432\u0440\u0435\u043C\u044F \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0438."
  readyText: "\u0412\u043E\u0439 \u0437\u0430\u0442\u0438\u0445. \u0412\u0435\u0440\u043D\u0438\u0441\u044C
    \u043A\u043E \u043C\u043D\u0435, \u043F\u043E\u043A\u0430 \u0441\u0442\u0430\u044F
    \u043D\u0435 \u043F\u0440\u0438\u0448\u043B\u0430 \u0432 \u0441\u0435\u0431\u044F."
  completedText: "\u0425\u043E\u0440\u043E\u0448\u0430\u044F \u043E\u0445\u043E\u0442\u0430.
    \u0422\u0435\u043F\u0435\u0440\u044C \u0441\u0435\u0432\u0435\u0440\u043D\u044B\u0439
    \u043F\u0440\u043E\u0445\u043E\u0434 \u0441\u0442\u0430\u043D\u0435\u0442 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u0435\u0435."
  objective:
    objectiveType: 0
    targetId: wolf_alpha
    displayText: "\u041F\u043E\u0431\u0435\u0436\u0434\u0451\u043D \u0432\u043E\u0436\u0430\u043A
      \u0441\u0442\u0430\u0438"
    readyText: "\u0412\u0435\u0440\u043D\u0438\u0442\u0435\u0441\u044C \u043A \u043A\u0430\u043F\u0438\u0442\u0430\u043D\u0443
      \u0441\u0442\u0440\u0430\u0436\u0438"
    requiredCount: 1
  reward:
    experience: 160
